AI_TEST_ENV=local
AI_TEST_TIMEOUT_SECONDS=30
AI_TEST_DEFAULT_SCORE_THRESHOLD=0.8
AI_TEST_CASE_FILE=
AI_TEST_CASE_DIR=
AI_TEST_CASE_RESULTS_FILE=reports/current/case_results.jsonl
AI_TEST_RUNTIME_PARAMS_FILE=
AI_TEST_API_TOKEN=
AI_TEST_JUDGE_API_KEY=

# ByteHouse / Skill runtime params can also be injected through env vars.
BYTEHOUSE_HOST=
BYTEHOUSE_PORT=
BYTEHOUSE_USER=
BYTEHOUSE_PASSWORD=
BYTEHOUSE_SECURE=true
BYTEHOUSE_VERIFY=true

# OpenClaw / ArkClaw SSH runtime params.
OPENCLAW_HOST=
OPENCLAW_PORT=22
OPENCLAW_USERNAME=
OPENCLAW_PASSWORD=
OPENCLAW_PRIVATE_KEY_FILE=
OPENCLAW_PASSPHRASE=
OPENCLAW_KNOWN_HOSTS=
OPENCLAW_STRICT_HOST_KEY=true
OPENCLAW_CONNECT_TIMEOUT=30
OPENCLAW_COMMAND_TIMEOUT=120
OPENCLAW_MODE=agent
OPENCLAW_AGENT_NAME=main
OPENCLAW_AGENT_TIMEOUT=180
